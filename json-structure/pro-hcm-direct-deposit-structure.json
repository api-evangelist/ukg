{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ukg/refs/heads/main/json-structure/pro-hcm-direct-deposit-structure.json",
  "name": "DirectDeposit",
  "description": "Employee direct deposit banking information",
  "type": "object",
  "properties": {
    "accountId": {
      "type": "string",
      "description": "Account identifier",
      "example": "EMP001"
    },
    "bankName": {
      "type": "string",
      "description": "Bank name",
      "example": "First National Bank"
    },
    "accountType": {
      "type": "string",
      "description": "Account type",
      "example": "Checking",
      "enum": [
        "Checking",
        "Savings"
      ]
    },
    "depositType": {
      "type": "string",
      "description": "Deposit distribution type",
      "example": "Remainder",
      "enum": [
        "Amount",
        "Percentage",
        "Remainder"
      ]
    },
    "depositAmount": {
      "type": "double",
      "description": "Deposit amount or percentage",
      "example": 1.0
    },
    "priority": {
      "type": "int32",
      "description": "Processing priority order",
      "example": 1
    }
  }
}