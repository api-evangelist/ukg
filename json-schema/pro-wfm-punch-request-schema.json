{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ukg/refs/heads/main/json-schema/pro-wfm-punch-request-schema.json",
  "title": "PunchRequest",
  "description": "Request to create a clock punch",
  "type": "object",
  "required": [
    "punchTime",
    "punchType"
  ],
  "properties": {
    "punchTime": {
      "type": "string",
      "format": "date-time",
      "description": "Punch timestamp",
      "example": "2026-01-15T09:00:00Z"
    },
    "punchType": {
      "type": "string",
      "description": "Type of punch",
      "example": "In",
      "enum": [
        "In",
        "Out",
        "Transfer"
      ]
    },
    "locationId": {
      "type": "string",
      "description": "Location identifier",
      "example": "EMP001"
    },
    "jobCode": {
      "type": "string",
      "description": "Job code for this punch",
      "example": "example-value"
    }
  }
}